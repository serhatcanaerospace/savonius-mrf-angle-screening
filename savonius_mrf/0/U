FoamFile
{
    version     2.0;
    format      ascii;
    class       volVectorField;
    location    "0";
    object      U;
}

#include        "include/initialConditions"

dimensions      [0 1 -1 0 0 0 0];
internalField   $flowVelocity;

boundaryField
{
    #include "include/fixedInlet"

    outlet
    {
        type            inletOutlet;
        inletValue      uniform (0 0 0);
        value           $flowVelocity;
    }

    // MRF: rotor wall is stationary relative to the rotating frame -
    // no mesh motion, so this is a plain fixedValue (0 0 0).
    Savonius
    {
        type            fixedValue;
        value           uniform (0 0 0);
    }

    #include "include/frontBackTopBottomPatches"
}
