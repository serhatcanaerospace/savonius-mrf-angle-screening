#!/bin/bash
cd "${0%/*}" || exit 1

source "${HOME}/OpenFOAM/OpenFOAM-8/etc/bashrc"
. "$WM_PROJECT_DIR"/bin/tools/RunFunctions
set -e

STL=constant/triSurface/rotorBlade.stl
if [ ! -f "$STL" ]; then
    echo "HATA: $STL bulunamadi."
    echo "Bu case'in kanadi -90 derece (saat yonunde) dondurulmustur - otomatik"
    echo "geri getirme yapilmiyor, referans (yatay) STL yanlislikla buraya"
    echo "kopyalanirsa deney sessizce gecersiz olur. Yeniden uretmek icin:"
    echo "  python3 ../analysis_scripts/rotate_blade.py ../geometry/rotorBlade_horizontal.stl $STL -90"
    exit 1
fi

foamListTimes -rm
foamCleanPolyMesh
rm -rf VTK postProcessing processor*
rm -f log.blockMesh log.snappyHexMesh log.topoSet log.createPatch log.checkMesh log.surfaceCheck

surfaceCheck "$STL" > log.surfaceCheck 2>&1
rm -f zone_rotorBlade.vtk rotorBlade_*.obj

runApplication -overwrite blockMesh
runApplication -overwrite snappyHexMesh -overwrite
runApplication -overwrite topoSet
runApplication -overwrite createPatch -overwrite
runApplication -overwrite checkMesh -allTopology -allGeometry
if grep -Eq 'Total number of faces on empty patches|highly skew|Cells with small determinant|negative volume|zero or negative face area|Face area magnitudes.*Failed|Cell volumes.*Failed|Number of regions: ([2-9]|[1-9][0-9]+)' log.checkMesh; then
    echo "HATA: mesh kalite kontrollerinden kaldi. Cozucu calistirilmamali."
    exit 1
fi

echo "Allrun-pre finished. Check log.checkMesh before running the solver."
