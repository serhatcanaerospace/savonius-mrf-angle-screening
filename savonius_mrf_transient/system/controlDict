FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      controlDict;
}

// Transient MRF: blade angle frozen (same as savonius_mrf), but flow field
// is now allowed to evolve in real time (pimpleFoam) instead of iterating
// to a single steady state (simpleFoam). This gives a real, physically
// meaningful animation of the wake developing/shedding behind the fixed
// blade - unlike simpleFoam's pseudo-time iterations.

application     pimpleFoam;

startFrom       latestTime;
startTime       0;

stopAt          endTime;
endTime         0.65;

deltaT          0.0001;

adjustTimeStep  yes;
maxCo           1;
maxDeltaT       0.0005;

writeControl    adjustableRunTime;
writeInterval   0.02;

purgeWrite      20;

writeFormat     binary;
writePrecision  7;
writeCompression off;

timeFormat      general;
timePrecision   6;

runTimeModifiable true;

functions
{
    #include "forceCoeffs"
}
